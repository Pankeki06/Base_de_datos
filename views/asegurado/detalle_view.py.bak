"""Vista de detalle de asegurado con 4 pestañas."""

from __future__ import annotations

import flet as ft
from controllers.asegurado_controller import AseguradoController
from controllers.beneficiario_controller import BeneficiarioController
from controllers.beneficio_controller import BeneficioController
from controllers.poliza_controller import PolizaController
from controllers.seguimiento_controller import SeguimientoController
from services.session_manager import obtener_agente

# ─── Colores ────────────────────────────────────────────────────────────────
_BG = "#0F1117"
_SIDEBAR = "#13161F"
_CARD = "#1A1D27"
_CARD2 = "#1E2235"
_ACCENT = "#00C17C"
_TEXT = "#E8EAF0"
_MUTED = "#6B7280"
_BORDER = "#2D3148"
_ERROR = "#EF4444"
_WARN = "#F59E0B"
_TIPO_COLOR = {
    "Vida": ("#00C17C", "#0D3B2E"),
    "Autos": ("#6366F1", "#1A1A3E"),
    "Hogar": ("#F59E0B", "#2D1F0A"),
    "Salud": ("#06B6D4", "#0A2233"),
}
_ESTATUS_COLOR = {
    "activa": ("#00C17C", "#0D3B2E"),
    "vencida": ("#EF4444", "#3B1A1A"),
    "cancelada": ("#9CA3AF", "#2D2D2D"),
}
_RESULTADO_COLOR = {
    "resuelto": ("#00C17C", "#0D3B2E"),
    "pendiente": ("#F59E0B", "#2D1F0A"),
    "sin_respuesta": ("#9CA3AF", "#2D2D2D"),
}


def _badge(label: str, fg: str, bg: str) -> ft.Container:
    return ft.Container(
        content=ft.Text(label, size=10, weight=ft.FontWeight.W_600, color=fg),
        bgcolor=bg,
        padding=ft.padding.symmetric(horizontal=8, vertical=3),
        border_radius=20,
    )


def _label_val(label: str, val: str) -> ft.Column:
    return ft.Column(
        [
            ft.Text(label.upper(), size=10, color=_MUTED, weight=ft.FontWeight.W_600),
            ft.Text(val or "—", size=14, color=_TEXT),
        ],
        spacing=3,
    )


def _sidebar_mini(navigate) -> ft.Container:
    from views.dashboard_view import _sidebar
    from services.session_manager import obtener_agente
    agente = obtener_agente()
    nombre = f"{agente.nombre} {agente.apellido_paterno}" if agente else "Agente"
    return _sidebar(navigate, nombre)


class DetalleAseguradoView:
    def __init__(self, page: ft.Page, navigate, id_asegurado: int) -> None:
        self._page = page
        self._navigate = navigate
        self._id = id_asegurado
        self._asegurado = None
        self._polizas = []
        self._beneficiarios = []
        self._seguimientos = []
        self._seg_col_ref = ft.Ref[ft.Column]()

    def build(self) -> ft.Control:
        res = AseguradoController.get_asegurado_by_id(self._id)
        if not res["ok"]:
            return ft.Container(
                content=ft.Text("Asegurado no encontrado", color=_ERROR),
                expand=True, bgcolor=_BG,
            )
        self._asegurado = res["data"]

        pol_res = PolizaController.get_polizas_by_asegurado(self._id)
        self._polizas = pol_res.get("data", []) if pol_res["ok"] else []

        ben_res = BeneficiarioController.get_beneficiarios_by_asegurado(self._id)
        self._beneficiarios = list(ben_res.get("data", []) if ben_res["ok"] else [])

        seg_res = SeguimientoController.get_seguimientos_by_asegurado(self._id)
        self._seguimientos = seg_res.get("data", []) if seg_res["ok"] else []

        sidebar = _sidebar_mini(self._navigate)
        main = self._build_main()

        return ft.Container(
            content=ft.Row([sidebar, main], spacing=0, expand=True),
            expand=True,
            bgcolor=_BG,
        )

    def _build_main(self) -> ft.Container:
        a = self._asegurado
        nombre_completo = f"{a.nombre} {a.apellido_paterno} {a.apellido_materno}"
        initials = (a.nombre[0] + a.apellido_paterno[0]).upper()

        # Header
        header = ft.Container(
            content=ft.Column(
                [
                    ft.Row(
                        [
                            ft.TextButton(
                                "Registry / Insured Clients",
                                style=ft.ButtonStyle(color=_MUTED),
                                on_click=lambda e: self._navigate("/dashboard"),
                            ),
                        ],
                    ),
                    ft.Row(
                        [
                            ft.Column(
                                [
                                    ft.Text(nombre_completo, size=26,
                                            weight=ft.FontWeight.BOLD, color=_TEXT),
                                    ft.Row(
                                        [
                                            ft.Icon(ft.Icons.LOCATION_ON_OUTLINED,
                                                    size=14, color=_MUTED),
                                            ft.Text(
                                                f"{a.municipio}, {a.estado}",
                                                size=13, color=_MUTED),
                                        ],
                                        spacing=4,
                                    ),
                                ],
                                spacing=4,
                            ),
                            ft.Container(expand=True),
                            ft.OutlinedButton(
                                content=ft.Row(
                                    [ft.Icon(ft.Icons.DOWNLOAD_OUTLINED, size=16),
                                     ft.Text("Expediente", size=13)],
                                    spacing=6,
                                ),
                                style=ft.ButtonStyle(
                                    color=_TEXT,
                                    side={ft.ControlState.DEFAULT: ft.BorderSide(1, _BORDER)},
                                    shape=ft.RoundedRectangleBorder(radius=8),
                                ),
                            ),
                            ft.ElevatedButton(
                                content=ft.Row(
                                    [ft.Icon(ft.Icons.SEND_ROUNDED, size=16),
                                     ft.Text("Contactar", size=13)],
                                    spacing=6,
                                ),
                                style=ft.ButtonStyle(
                                    bgcolor={ft.ControlState.DEFAULT: _ACCENT},
                                    color={ft.ControlState.DEFAULT: "#000000"},
                                    shape=ft.RoundedRectangleBorder(radius=8),
                                ),
                                on_click=lambda e: self._open_seguimiento_modal(),
                            ),
                        ],
                        vertical_alignment=ft.CrossAxisAlignment.CENTER,
                    ),
                ],
                spacing=6,
            ),
            padding=ft.padding.symmetric(horizontal=28, vertical=20),
            border=ft.border.only(bottom=ft.BorderSide(1, _BORDER)),
        )

        # Tabs
        tab_bar = ft.TabBar(
            tabs=[
                ft.Tab(label="Datos Personales"),
                ft.Tab(label="Pólizas"),
                ft.Tab(label="Beneficiarios"),
                ft.Tab(label="Historial de Seguimiento"),
            ],
            tab_alignment=ft.TabAlignment.START,
            indicator_color=_ACCENT,
            label_color=_TEXT,
            unselected_label_color=_MUTED,
            scrollable=False,
        )

        def _tab_content(ctrl) -> ft.Container:
            return ft.Container(
                content=ft.Column(
                    [ctrl],
                    scroll=ft.ScrollMode.AUTO,
                    expand=True,
                ),
                padding=ft.padding.symmetric(horizontal=28, vertical=20),
                expand=True,
            )

        tab_view = ft.TabBarView(
            controls=[
                _tab_content(self._build_tab_datos()),
                _tab_content(self._build_tab_polizas()),
                _tab_content(self._build_tab_beneficiarios()),
                _tab_content(self._build_tab_seguimientos()),
            ],
            expand=1,
        )

        tabs = ft.Tabs(
            content=ft.Column([tab_bar, tab_view], expand=1),
            length=4,
            selected_index=0,
            animation_duration=200,
        )

        return ft.Container(
            content=ft.Column(
                [header, tabs],
                spacing=0,
                expand=True,
            ),
            expand=True,
            bgcolor=_BG,
        )

    # ── Tab 1: Datos personales ──────────────────────────────────────────────
    def _build_tab_datos(self) -> ft.Control:
        a = self._asegurado
        nombre_completo = f"{a.nombre} {a.apellido_paterno} {a.apellido_materno}"
        direccion = f"{a.calle} {a.numero_exterior}"
        if a.numero_interior:
            direccion += f" Int. {a.numero_interior}"
        direccion += f", Col. {a.colonia}, {a.municipio}, {a.estado} C.P. {a.codigo_postal}"

        card = ft.Container(
            content=ft.Column(
                [
                    ft.Row(
                        [
                            ft.Text("Información General", size=16,
                                    weight=ft.FontWeight.W_600, color=_TEXT),
                            ft.Container(expand=True),
                            ft.TextButton(
                                content=ft.Row(
                                    [ft.Icon(ft.Icons.EDIT_OUTLINED, size=14),
                                     ft.Text("Editar", size=13)],
                                    spacing=4,
                                ),
                                style=ft.ButtonStyle(color=_ACCENT),
                                on_click=lambda e: self._navigate(
                                    "/asegurado/editar", asegurado=a),
                            ),
                        ],
                    ),
                    ft.Divider(color=_BORDER, height=16),
                    ft.ResponsiveRow(
                        [
                            ft.Column(
                                [_label_val("Nombre Completo", nombre_completo)],
                                col={"xs": 12, "md": 6},
                            ),
                            ft.Column(
                                [_label_val("ID Fiscal / RFC", a.rfc)],
                                col={"xs": 12, "md": 6},
                            ),
                            ft.Column(
                                [_label_val("Correo Electrónico", a.correo or "—")],
                                col={"xs": 12, "md": 6},
                            ),
                            ft.Column(
                                [_label_val("Teléfono Móvil", a.celular or "—")],
                                col={"xs": 12, "md": 6},
                            ),
                            ft.Column(
                                [_label_val("Dirección Física", direccion)],
                                col={"xs": 12},
                            ),
                        ],
                        spacing=16,
                    ),
                ],
                spacing=8,
            ),
            padding=20,
            bgcolor=_CARD,
            border_radius=12,
            border=ft.border.all(1, _BORDER),
        )

        # Pólizas activas summary
        pol_cards = []
        for p in self._polizas:
            beneficios_res = BeneficioController.get_beneficios_by_poliza(p.id_poliza)
            bens = beneficios_res.get("data", []) if beneficios_res["ok"] else []
            fg, bg = _ESTATUS_COLOR.get(p.estatus, ("#9CA3AF", "#2D2D2D"))
            tipo_fg, tipo_bg = _TIPO_COLOR.get(p.tipo_seguro, ("#9CA3AF", "#2D2D2D"))
            ben_badges = ft.Row(
                [
                    ft.Container(
                        content=ft.Text(b.nombre_beneficio.upper(), size=9,
                                        weight=ft.FontWeight.W_600, color=_MUTED),
                        bgcolor=_CARD2,
                        padding=ft.padding.symmetric(horizontal=6, vertical=2),
                        border_radius=4,
                    )
                    for b in bens[:3]
                ],
                spacing=4,
                wrap=True,
            )
            pol_cards.append(
                ft.Container(
                    content=ft.Row(
                        [
                            ft.Container(
                                content=ft.Icon(
                                    ft.Icons.DIRECTIONS_CAR_ROUNDED
                                    if "Auto" in p.tipo_seguro
                                    else ft.Icons.HOME_ROUNDED
                                    if "Hogar" in p.tipo_seguro
                                    else ft.Icons.FAVORITE_ROUNDED,
                                    color=tipo_fg, size=22,
                                ),
                                bgcolor=tipo_bg,
                                padding=10,
                                border_radius=8,
                            ),
                            ft.Column(
                                [
                                    ft.Row(
                                        [
                                            ft.Text(p.tipo_seguro, size=14,
                                                    weight=ft.FontWeight.W_600,
                                                    color=_TEXT),
                                            _badge(p.estatus.upper(), fg, bg),
                                        ],
                                        spacing=8,
                                    ),
                                    ft.Text(f"Vence: {p.fecha_vencimiento}",
                                            size=12, color=_MUTED),
                                    ben_badges,
                                ],
                                spacing=4,
                                expand=True,
                            ),
                            ft.Text(f"${p.prima_mensual:.2f}/mes",
                                    size=15, weight=ft.FontWeight.BOLD,
                                    color=_TEXT),
                        ],
                        spacing=12,
                        vertical_alignment=ft.CrossAxisAlignment.CENTER,
                    ),
                    padding=14,
                    bgcolor=_CARD,
                    border_radius=10,
                    border=ft.border.all(1, _BORDER),
                )
            )

        pol_section = ft.Container(
            content=ft.Column(
                [
                    ft.Row(
                        [
                            ft.Text("Pólizas Activas", size=16,
                                    weight=ft.FontWeight.W_600, color=_TEXT),
                            ft.Container(
                                content=ft.Text(
                                    f"{len([p for p in self._polizas if p.estatus == 'activa'])} ACTIVAS",
                                    size=10, weight=ft.FontWeight.W_600, color=_ACCENT),
                                bgcolor=ft.Colors.with_opacity(0.15, _ACCENT),
                                padding=ft.padding.symmetric(horizontal=8, vertical=3),
                                border_radius=20,
                            ),
                        ],
                    ),
                    ft.Divider(color=_BORDER, height=12),
                    *pol_cards,
                ],
                spacing=10,
            ),
            padding=20,
            bgcolor=_CARD,
            border_radius=12,
            border=ft.border.all(1, _BORDER),
        )

        return ft.Column([card, pol_section], spacing=16)

    # ── Tab 2: Pólizas ──────────────────────────────────────────────────────
    def _build_tab_polizas(self) -> ft.Control:
        cards = []
        for p in self._polizas:
            beneficios_res = BeneficioController.get_beneficios_by_poliza(p.id_poliza)
            bens = beneficios_res.get("data", []) if beneficios_res["ok"] else []
            fg, bg = _ESTATUS_COLOR.get(p.estatus, ("#9CA3AF", "#2D2D2D"))
            tipo_fg, tipo_bg = _TIPO_COLOR.get(p.tipo_seguro, ("#9CA3AF", "#2D2D2D"))

            ben_list = ft.Column(
                [
                    ft.Row(
                        [
                            ft.Icon(ft.Icons.CHECK_CIRCLE_OUTLINE_ROUNDED,
                                    size=14, color=_ACCENT),
                            ft.Text(b.nombre_beneficio, size=13, color=_TEXT),
                            ft.Container(expand=True),
                            ft.Text(f"${b.monto_cobertura:,.0f}", size=12, color=_MUTED),
                        ],
                        spacing=8,
                    )
                    for b in bens
                ],
                spacing=6,
            )

            cards.append(
                ft.Container(
                    content=ft.Column(
                        [
                            ft.Row(
                                [
                                    ft.Container(
                                        content=ft.Icon(
                                            ft.Icons.DIRECTIONS_CAR_ROUNDED
                                            if "Auto" in p.tipo_seguro
                                            else ft.Icons.HOME_ROUNDED
                                            if "Hogar" in p.tipo_seguro
                                            else ft.Icons.FAVORITE_ROUNDED,
                                            color=tipo_fg, size=22,
                                        ),
                                        bgcolor=tipo_bg,
                                        padding=10,
                                        border_radius=8,
                                    ),
                                    ft.Column(
                                        [
                                            ft.Row(
                                                [
                                                    ft.Text(p.tipo_seguro, size=15,
                                                            weight=ft.FontWeight.W_600,
                                                            color=_TEXT),
                                                    _badge(p.estatus.upper(), fg, bg),
                                                ],
                                                spacing=8,
                                            ),
                                            ft.Text(p.numero_poliza, size=12, color=_MUTED),
                                        ],
                                        spacing=3,
                                        expand=True,
                                    ),
                                    ft.Column(
                                        [
                                            ft.Text(f"${p.prima_mensual:.2f}/mes",
                                                    size=16, weight=ft.FontWeight.BOLD,
                                                    color=_TEXT),
                                            ft.Text(
                                                f"{p.fecha_inicio} → {p.fecha_vencimiento}",
                                                size=11, color=_MUTED),
                                        ],
                                        spacing=2,
                                        horizontal_alignment=ft.CrossAxisAlignment.END,
                                    ),
                                ],
                                spacing=12,
                                vertical_alignment=ft.CrossAxisAlignment.CENTER,
                            ),
                            ft.Divider(color=_BORDER, height=12),
                            ft.Text("Beneficios incluidos", size=12,
                                    color=_MUTED, weight=ft.FontWeight.W_500),
                            ft.Container(height=4),
                            ben_list,
                        ],
                        spacing=8,
                    ),
                    padding=16,
                    bgcolor=_CARD,
                    border_radius=12,
                    border=ft.border.all(1, _BORDER),
                )
            )

        return ft.Column(
            [ft.Text("Pólizas", size=16, weight=ft.FontWeight.W_600, color=_TEXT),
             *cards],
            spacing=12,
        )

    # ── Tab 3: Beneficiarios ─────────────────────────────────────────────────
    def _build_tab_beneficiarios(self) -> ft.Control:
        tabla_ref = ft.Ref[ft.Column]()

        def refresh_tabla():
            ben_res = BeneficiarioController.get_beneficiarios_by_asegurado(self._id)
            self._beneficiarios = list(ben_res.get("data", []) if ben_res["ok"] else [])
            col = tabla_ref.current
            col.controls.clear()
            col.controls.extend(self._beneficiario_rows(refresh_tabla))
            # Suma
            total = sum(b.porcentaje_participacion for b in self._beneficiarios)
            suma_text.value = f"Suma de porcentajes no debe exceder 100%. Actualmente: {total:.0f}%."
            suma_text.color = _ERROR if total > 100 else _ACCENT
            self._page.update()

        warn_text = ft.Ref[ft.Text]()
        suma_text = ft.Text("", size=12, color=_ACCENT)

        total = sum(b.porcentaje_participacion for b in self._beneficiarios)
        suma_text.value = f"Suma de porcentajes no debe exceder 100%. Actualmente: {total:.0f}%."
        suma_text.color = _ERROR if total > 100 else _ACCENT

        tabla_col = ft.Column(
            ref=tabla_ref,
            controls=self._beneficiario_rows(refresh_tabla),
            spacing=0,
        )

        def open_add(e):
            self._open_beneficiario_modal(None, refresh_tabla)

        header_row = ft.Row(
            [
                ft.Text("Nombre", expand=3, size=12, color=_MUTED,
                        weight=ft.FontWeight.W_600),
                ft.Text("Parentesco", expand=2, size=12, color=_MUTED,
                        weight=ft.FontWeight.W_600),
                ft.Text("Porcentaje", expand=1, size=12, color=_MUTED,
                        weight=ft.FontWeight.W_600),
                ft.Container(width=60),
            ],
            spacing=12,
        )

        return ft.Container(
            content=ft.Column(
                [
                    ft.Row(
                        [
                            ft.Text("Beneficiarios", size=16,
                                    weight=ft.FontWeight.W_600, color=_TEXT),
                            ft.Container(expand=True),
                            ft.ElevatedButton(
                                content=ft.Row(
                                    [ft.Icon(ft.Icons.PERSON_ADD_ROUNDED, size=14),
                                     ft.Text("Agregar", size=13)],
                                    spacing=6,
                                ),
                                style=ft.ButtonStyle(
                                    bgcolor={ft.ControlState.DEFAULT: _ACCENT},
                                    color={ft.ControlState.DEFAULT: "#000000"},
                                    shape=ft.RoundedRectangleBorder(radius=8),
                                ),
                                on_click=open_add,
                            ),
                        ],
                    ),
                    ft.Divider(color=_BORDER, height=8),
                    ft.Container(
                        content=ft.Column(
                            [
                                ft.Container(
                                    content=header_row,
                                    padding=ft.padding.symmetric(horizontal=12, vertical=8),
                                    bgcolor=_CARD2,
                                    border_radius=ft.border_radius.only(
                                        top_left=8, top_right=8),
                                ),
                                tabla_col,
                                ft.Divider(color=_BORDER, height=1),
                                ft.Container(
                                    content=ft.Row(
                                        [ft.Icon(ft.Icons.INFO_OUTLINED, size=13, color=_ACCENT),
                                         suma_text],
                                        spacing=6,
                                    ),
                                    padding=ft.padding.symmetric(horizontal=12, vertical=6),
                                    bgcolor=ft.Colors.with_opacity(0.08, _ACCENT),
                                    border_radius=ft.border_radius.only(
                                        bottom_left=8, bottom_right=8),
                                ),
                            ],
                            spacing=0,
                        ),
                        bgcolor=_CARD,
                        border_radius=10,
                        border=ft.border.all(1, _BORDER),
                    ),
                ],
                spacing=12,
            ),
            expand=True,
        )

    def _beneficiario_rows(self, refresh_cb) -> list:
        rows = []
        for b in self._beneficiarios:
            def on_delete(e, bid=b.id_beneficiario):
                BeneficiarioController.delete_beneficiario(bid)
                refresh_cb()

            rows.append(
                ft.Container(
                    content=ft.Row(
                        [
                            ft.Text(b.nombre_completo, expand=3, size=13, color=_TEXT),
                            ft.Text(b.parentesco, expand=2, size=13, color=_MUTED),
                            ft.Text(f"{b.porcentaje_participacion:.0f}%",
                                    expand=1, size=13, color=_ACCENT,
                                    weight=ft.FontWeight.W_600),
                            ft.Container(
                                content=ft.IconButton(
                                    icon=ft.Icons.DELETE_OUTLINE_ROUNDED,
                                    icon_color=_ERROR,
                                    icon_size=16,
                                    tooltip="Eliminar",
                                    on_click=on_delete,
                                ),
                                width=60,
                            ),
                        ],
                        spacing=12,
                        vertical_alignment=ft.CrossAxisAlignment.CENTER,
                    ),
                    padding=ft.padding.symmetric(horizontal=12, vertical=10),
                    border=ft.border.only(bottom=ft.BorderSide(1, _BORDER)),
                )
            )
        return rows

    def _open_beneficiario_modal(self, beneficiario, refresh_cb) -> None:
        nombre_f = ft.TextField(
            label="Nombre completo",
            value=beneficiario.nombre_completo if beneficiario else "",
            border_color=_BORDER, focused_border_color=_ACCENT,
            label_style=ft.TextStyle(color=_MUTED),
            text_style=ft.TextStyle(color=_TEXT),
            bgcolor=_CARD,
        )
        parentesco_f = ft.TextField(
            label="Parentesco",
            value=beneficiario.parentesco if beneficiario else "",
            hint_text="Ej. Cónyuge, Hijo, Padre",
            border_color=_BORDER, focused_border_color=_ACCENT,
            label_style=ft.TextStyle(color=_MUTED),
            text_style=ft.TextStyle(color=_TEXT),
            bgcolor=_CARD,
        )
        porcentaje_f = ft.TextField(
            label="Porcentaje (%)",
            value=str(beneficiario.porcentaje_participacion) if beneficiario else "",
            border_color=_BORDER, focused_border_color=_ACCENT,
            label_style=ft.TextStyle(color=_MUTED),
            text_style=ft.TextStyle(color=_TEXT),
            bgcolor=_CARD,
            keyboard_type=ft.KeyboardType.NUMBER,
        )
        error_t = ft.Text("", color=_ERROR, size=12)

        def on_guardar(e):
            total_actual = sum(
                b.porcentaje_participacion for b in self._beneficiarios
            )
            try:
                pct = float(porcentaje_f.value or "0")
            except ValueError:
                error_t.value = "El porcentaje debe ser un número."
                self._page.update()
                return
            if total_actual + pct > 100:
                error_t.value = f"La suma superaría 100% (actual: {total_actual:.0f}%)."
                self._page.update()
                return
            data = {
                "id_asegurado": self._id,
                "nombre_completo": nombre_f.value,
                "parentesco": parentesco_f.value,
                "porcentaje_participacion": pct,
            }
            result = BeneficiarioController.create_beneficiario(data)
            if result["ok"]:
                self._page.pop_dialog()
                refresh_cb()
            else:
                error_t.value = result["error"]
                self._page.update()

        dlg = ft.AlertDialog(
            modal=True,
            title=ft.Text("Agregar beneficiario", color=_TEXT),
            bgcolor=_CARD,
            content=ft.Column(
                [nombre_f, parentesco_f, porcentaje_f, error_t],
                spacing=12,
                tight=True,
                width=380,
            ),
            actions=[
                ft.TextButton("Cancelar",
                              style=ft.ButtonStyle(color=_MUTED),
                              on_click=lambda e: self._page.pop_dialog()),
                ft.ElevatedButton(
                    "Guardar",
                    style=ft.ButtonStyle(
                        bgcolor={ft.ControlState.DEFAULT: _ACCENT},
                        color={ft.ControlState.DEFAULT: "#000000"},
                        shape=ft.RoundedRectangleBorder(radius=8),
                    ),
                    on_click=on_guardar,
                ),
            ],
            actions_alignment=ft.MainAxisAlignment.END,
        )
        self._page.show_dialog(dlg)

    # ── Tab 4: Historial de seguimientos ──────────────────────────────────────
    def _build_tab_seguimientos(self) -> ft.Control:
        seguimientos_col = ft.Column(ref=self._seg_col_ref, spacing=0)
        seguimientos_col.controls.extend(self._seguimiento_items())

        def on_nuevo(e):
            self._open_seguimiento_modal()

        return ft.Container(
            content=ft.Column(
                [
                    ft.Row(
                        [
                            ft.Text("Historial de Seguimiento", size=16,
                                    weight=ft.FontWeight.W_600, color=_TEXT),
                            ft.Container(expand=True),
                            ft.ElevatedButton(
                                content=ft.Row(
                                    [ft.Icon(ft.Icons.ADD_ROUNDED, size=14),
                                     ft.Text("Nuevo seguimiento", size=13)],
                                    spacing=6,
                                ),
                                style=ft.ButtonStyle(
                                    bgcolor={ft.ControlState.DEFAULT: _ACCENT},
                                    color={ft.ControlState.DEFAULT: "#000000"},
                                    shape=ft.RoundedRectangleBorder(radius=8),
                                ),
                                on_click=on_nuevo,
                            ),
                        ],
                    ),
                    ft.Container(height=8),
                    ft.Container(
                        content=seguimientos_col,
                        bgcolor=_CARD,
                        border_radius=12,
                        border=ft.border.all(1, _BORDER),
                        padding=0,
                    ),
                ],
                spacing=12,
            ),
            expand=True,
        )

    def _seguimiento_items(self) -> list:
        items = []
        for s in sorted(self._seguimientos, key=lambda x: x.fecha_hora, reverse=True):
            fg, bg = _RESULTADO_COLOR.get(s.resultado, ("#9CA3AF", "#2D2D2D"))
            tipo_icon = {
                "llamada": ft.Icons.PHONE_ROUNDED,
                "visita": ft.Icons.PERSON_ROUNDED,
                "mensaje": ft.Icons.MESSAGE_ROUNDED,
            }.get(s.tipo_contacto, ft.Icons.CHAT_BUBBLE_OUTLINE_ROUNDED)

            items.append(
                ft.Container(
                    content=ft.Row(
                        [
                            ft.Container(
                                content=ft.Icon(tipo_icon, size=16, color=_ACCENT),
                                bgcolor=ft.Colors.with_opacity(0.12, _ACCENT),
                                padding=8,
                                border_radius=8,
                                width=36, height=36,
                            ),
                            ft.Column(
                                [
                                    ft.Row(
                                        [
                                            ft.Text(
                                                str(s.fecha_hora.date()),
                                                size=11, color=_MUTED),
                                            _badge(s.tipo_contacto.upper(), _MUTED, _CARD2),
                                        ],
                                        spacing=8,
                                    ),
                                    ft.Text(s.observaciones, size=13, color=_TEXT),
                                    ft.Row(
                                        [_badge(s.resultado.replace("_", " ").upper(),
                                                fg, bg)],
                                    ),
                                ],
                                spacing=4,
                                expand=True,
                            ),
                        ],
                        spacing=12,
                        vertical_alignment=ft.CrossAxisAlignment.START,
                    ),
                    padding=ft.padding.symmetric(horizontal=16, vertical=12),
                    border=ft.border.only(bottom=ft.BorderSide(1, _BORDER)),
                )
            )
        return items

    def _open_seguimiento_modal(self) -> None:
        agente = obtener_agente()
        tipo_dd = ft.Dropdown(
            label="Tipo de contacto",
            options=[
                ft.dropdown.Option(key="llamada", text="Llamada"),
                ft.dropdown.Option(key="visita", text="Visita"),
                ft.dropdown.Option(key="mensaje", text="Mensaje"),
            ],
            border_color=_BORDER,
            focused_border_color=_ACCENT,
            label_style=ft.TextStyle(color=_MUTED),
            text_style=ft.TextStyle(color=_TEXT),
            bgcolor=_CARD,
        )
        resultado_dd = ft.Dropdown(
            label="Resultado",
            options=[
                ft.dropdown.Option(key="resuelto", text="Resuelto"),
                ft.dropdown.Option(key="pendiente", text="Pendiente"),
                ft.dropdown.Option(key="sin_respuesta", text="Sin respuesta"),
            ],
            border_color=_BORDER,
            focused_border_color=_ACCENT,
            label_style=ft.TextStyle(color=_MUTED),
            text_style=ft.TextStyle(color=_TEXT),
            bgcolor=_CARD,
        )
        observaciones_f = ft.TextField(
            label="Observaciones",
            multiline=True,
            min_lines=3,
            max_lines=5,
            border_color=_BORDER,
            focused_border_color=_ACCENT,
            label_style=ft.TextStyle(color=_MUTED),
            text_style=ft.TextStyle(color=_TEXT),
            bgcolor=_CARD,
        )
        fecha_f = ft.TextField(
            label="Fecha del contacto (AAAA-MM-DD HH:MM)",
            hint_text="Ej. 2026-04-07 10:00",
            border_color=_BORDER,
            focused_border_color=_ACCENT,
            label_style=ft.TextStyle(color=_MUTED),
            text_style=ft.TextStyle(color=_TEXT),
            bgcolor=_CARD,
        )
        error_t = ft.Text("", color=_ERROR, size=12)

        def on_guardar(e):
            from datetime import datetime as dt
            try:
                fecha_hora = dt.strptime(
                    fecha_f.value.strip(), "%Y-%m-%d %H:%M"
                )
            except (ValueError, AttributeError):
                error_t.value = "Formato de fecha inválido. Use AAAA-MM-DD HH:MM."
                self._page.update()
                return

            data = {
                "id_asegurado": self._id,
                "id_agente": agente.id_agente if agente else 1,
                "tipo_contacto": tipo_dd.value,
                "resultado": resultado_dd.value,
                "observaciones": observaciones_f.value,
                "fecha_hora": fecha_hora,
            }
            result = SeguimientoController.create_seguimiento(data)
            if result["ok"]:
                self._page.pop_dialog()
                # Recargar seguimientos
                seg_res = SeguimientoController.get_seguimientos_by_asegurado(self._id)
                self._seguimientos = seg_res.get("data", []) if seg_res["ok"] else []
                if self._seg_col_ref.current is not None:
                    col = self._seg_col_ref.current
                    col.controls.clear()
                    col.controls.extend(self._seguimiento_items())
                    self._page.update()
            else:
                error_t.value = result["error"]
                self._page.update()

        dlg = ft.AlertDialog(
            modal=True,
            title=ft.Text("Nuevo Seguimiento", color=_TEXT),
            bgcolor=_CARD,
            content=ft.Column(
                [tipo_dd, resultado_dd, observaciones_f, fecha_f, error_t],
                spacing=12,
                tight=True,
                width=420,
            ),
            actions=[
                ft.TextButton("Cancelar",
                              style=ft.ButtonStyle(color=_MUTED),
                              on_click=lambda e: self._page.pop_dialog()),
                ft.ElevatedButton(
                    "Guardar",
                    style=ft.ButtonStyle(
                        bgcolor={ft.ControlState.DEFAULT: _ACCENT},
                        color={ft.ControlState.DEFAULT: "#000000"},
                        shape=ft.RoundedRectangleBorder(radius=8),
                    ),
                    on_click=on_guardar,
                ),
            ],
            actions_alignment=ft.MainAxisAlignment.END,
        )
        self._page.show_dialog(dlg)



